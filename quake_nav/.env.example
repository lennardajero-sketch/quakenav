# Copy this file to .env for local notes/config values.
# Do not commit the real .env file.

# Firebase project metadata. These values are used to recreate local Firebase
# config files, not loaded directly by Flutter in the current app.
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_NUMBER=YOUR_FIREBASE_PROJECT_NUMBER
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.REGION.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
FIREBASE_ANDROID_APP_ID=YOUR_ANDROID_APP_ID
FIREBASE_ANDROID_API_KEY=YOUR_ANDROID_API_KEY

# Android package configured in android/app/build.gradle.kts and Firebase.
ANDROID_PACKAGE_NAME=Quake.Nav
